# ─── MongoDB ──────────────────────────────────────────────────────────────────
# When using docker-compose, the hostname is the service name "mongo":
MONGO=mongodb://mongo:27017/blogapp

# For a remote Atlas cluster, replace with your connection string:
# MONGO=mongodb+srv://<user>:<password>@cluster.mongodb.net/blogapp

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── OpenRouter AI (Autocomplete) ─────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
